#!/bin/sh

REPO_ROOT="$(git rev-parse --show-toplevel)"
powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/check-expressions-placeholders.ps1"
STATUS=$?

if [ $STATUS -ne 0 ]; then
  echo "[pre-commit] Commit blocked by expressions.tmdl secret check."
  exit $STATUS
fi

exit 0
