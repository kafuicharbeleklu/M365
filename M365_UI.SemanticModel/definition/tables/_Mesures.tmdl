		formatString: 0
		lineageTag: 721c0db6-9da2-4405-bf14-696a7a768841

	measure LicencesInactives =
			VAR _affectees = COALESCE([LicencesAffectees], 0)
			VAR _actives = COALESCE([LicencesActives], 0)
			RETURN
			MAX(0, _affectees - _actives)
		formatString: 0
		lineageTag: bc241cca-a9cb-4b23-aa44-116c69afe4a2

	measure LicencesActives =
			VAR _actives =
				CALCULATE(
					[LicencesAffectees],
					TREATAS(
						CALCULATETABLE(
							VALUES(T_Utilisateurs_Dim[UserPrincipalName]),
							FILTER(
								T_Utilisateurs_Dim,
								TRIM(T_Utilisateurs_Dim[EtatActivite]) = "Actif"
							)
						),
						T_Affectations_Fact[UserPrincipalName]
					)
				)
			RETURN
			COALESCE(_actives, 0)
		formatString: 0
		lineageTag: ebbf9efb-9959-4a33-85ae-9250badf11e9

	measure TauxActiviteUtilisateurs =
			VAR _baseActiveAD = MAX(0, [NbHumainsTotal] - [NbHumainsDesactives])
			RETURN
			DIVIDE([NbHumainsActifs], _baseActiveAD, 0)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 6eb920b2-fbc7-468e-8b0c-3c3bfec39bbc

	measure CiblesNettoyage =
			
			[NbHumainsInactifs] + [NbHumainsJamaisConnectes] + [NbHumainsDesactives] + [NbBoitesInactives]
		formatString: 0
		lineageTag: 1dff5eaa-1029-474e-b468-877e79b6be82

	measure LicencesComptesBloques =
