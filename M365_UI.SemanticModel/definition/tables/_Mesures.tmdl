	measure LicencesInactives =
			VAR UsersDesactives =
				CALCULATETABLE(
					VALUES(T_Utilisateurs_Dim[UserPrincipalName]),
					REMOVEFILTERS(T_Utilisateurs_Dim[EtatActivite]),
					T_Utilisateurs_Dim[TypeCompte] = "Utilisateur",
					T_Utilisateurs_Dim[AccountEnabled] = FALSE()
				)
			VAR UsersInactifsActifs =
				CALCULATETABLE(
					VALUES(T_Utilisateurs_Dim[UserPrincipalName]),
					T_Utilisateurs_Dim[TypeCompte] = "Utilisateur",
					T_Utilisateurs_Dim[AccountEnabled] = TRUE(),
					T_Utilisateurs_Dim[CodeEtatActivite] IN {"INACTIF", "JAMAIS_CONNECTE"}
				)
			VAR AllInactifsUPN = UNION(UsersDesactives, UsersInactifsActifs)
			RETURN
			COALESCE(
				CALCULATE(
					[LicencesAffectees],
					TREATAS(AllInactifsUPN, T_Affectations_Fact[UserPrincipalName])
				),
				0
			)
		formatString: 0
		displayFolder: Licences
		lineageTag: bc241cca-a9cb-4b23-aa44-116c69afe4a2

	measure LicencesActives =
			VAR _affectees = [LicencesAffectees]
			VAR _inactives = COALESCE([LicencesInactives], 0)
			VAR _diff = _affectees - _inactives
			RETURN
			IF(
				ISBLANK(_affectees),
				BLANK(),
				IF(_diff < 0, 0, _diff)
			)
		formatString: 0
		displayFolder: Licences
		lineageTag: ebbf9efb-9959-4a33-85ae-9250badf11e9

	measure TauxActiviteUtilisateurs =
			VAR _baseActiveAD = MAX(0, [NbHumainsTotal] - [NbHumainsDesactives])
			RETURN
			DIVIDE([NbHumainsActifs], _baseActiveAD, 0)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Utilisateurs
		lineageTag: 6eb920b2-fbc7-468e-8b0c-3c3bfec39bbc

