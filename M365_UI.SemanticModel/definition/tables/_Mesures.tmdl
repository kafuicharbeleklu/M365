table _Mesures
	lineageTag: a850445f-f717-4463-a1d3-3d0a58d87076

	measure TotalUtilisateurs = [NbHumainsTotal] + [NbBoitesTotal]
		formatString: 0
		lineageTag: c66486e4-de02-4215-87fd-41094f88a934

	measure StockLicences = COALESCE(SUM(T_Produits_Dim[LicencesAchetees]), 0)
		formatString: 0
		lineageTag: 202b2563-2763-424c-9f16-716b53517aef

	/// Nombre de licences affectees (unique par AffectationID pour eviter les doublons de fanout)
	measure LicencesAffectees = COALESCE(DISTINCTCOUNT(T_Affectations_Fact[AffectationID]), 0)
		formatString: 0
		lineageTag: c9dd86b9-6901-43b1-a18a-5d0fcdc6444a

	measure LicencesDisponibles =
			VAR _stock = COALESCE([StockLicences], 0)
			VAR _affectees = COALESCE([LicencesAffectees], 0)
			RETURN
			_stock - _affectees
		formatString: 0
		lineageTag: c93ab035-a7e9-4aa5-a9ef-73a571e4f218

	measure NombreProduits = DISTINCTCOUNT(T_Produits_Dim[NomProduit])
		formatString: 0
		lineageTag: 050a0ed5-8639-4d4c-aaf7-17ffff7cd409

	measure TauxUtilisation = DIVIDE([LicencesAffectees], [StockLicences], 0)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 92b91ee1-e415-469f-affd-1fb7438e230e

	/// Total comptes humains (TypeCompte = "Utilisateur"), toutes catégories.
	/// Exclut les comptes techniques (EtatActivite = BLANK pour ceux-ci).
	measure NbHumainsTotal =
			COALESCE(
				[NbHumainsActifs]
				+ [NbHumainsInactifs]
				+ [NbHumainsJamaisConnectes]
				+ [NbInactifsM365]
				+ [NbHumainsDesactives],
				0
			)
		formatString: 0
		lineageTag: e14dc89f-4a3b-4283-94e2-021e753627a5

	measure NbHumainsActifs =
			COALESCE(
				CALCULATE(
					DISTINCTCOUNT(T_Utilisateurs_Dim[UserPrincipalName]),
					FILTER(
						T_Utilisateurs_Dim,
						TRIM(T_Utilisateurs_Dim[EtatActivite]) = "Actif"
					)
				),
				0
			)
		formatString: 0
		lineageTag: e7698b1d-b19f-4138-a8e2-e7447d74d67b

	measure NbHumainsInactifs =
			COALESCE(
				CALCULATE(
					DISTINCTCOUNT(T_Utilisateurs_Dim[UserPrincipalName]),
					FILTER(
						T_Utilisateurs_Dim,
						TRIM(T_Utilisateurs_Dim[EtatActivite]) = "Inactif (>90j)"
					)
				),
				0
			)
		formatString: 0
		lineageTag: 5a890ccd-4f5f-4bcc-aafe-1862cab49265

	measure NbHumainsJamaisConnectes =
			COALESCE(
				CALCULATE(
					DISTINCTCOUNT(T_Utilisateurs_Dim[UserPrincipalName]),
					T_Utilisateurs_Dim[AccountEnabled] = TRUE(),
					ISBLANK(T_Utilisateurs_Dim[LastSignIn])
				),
				0
			)
		formatString: 0
		lineageTag: 35b10d51-618f-45eb-8b4c-452c02750c1c

	measure NbHumainsDesactives =
			COALESCE(
				CALCULATE(
					DISTINCTCOUNT(T_Utilisateurs_Dim[UserPrincipalName]),
					REMOVEFILTERS(T_Utilisateurs_Dim[EtatActivite]),
					T_Utilisateurs_Dim[TypeCompte] = "Utilisateur",
					T_Utilisateurs_Dim[AccountEnabled] = FALSE()
				),
				0
			)
		formatString: 0
		lineageTag: ba0253cf-d1fd-4af9-b836-9ec65a10d6ae

	measure NbBoitesTotal =
			COALESCE(
				CALCULATE(
					COUNTROWS(T_Utilisateurs_Dim),
					REMOVEFILTERS(T_Utilisateurs_Dim[EtatActivite]),
					T_Utilisateurs_Dim[TypeCompte] = "Technique"
				),
				0
			)
		formatString: 0
		lineageTag: 4f8e1014-8fbe-4686-88eb-59651ad6bfec

	measure NbBoitesInactives =
			COALESCE(
				CALCULATE(
					COUNTROWS(T_Utilisateurs_Dim),
					REMOVEFILTERS(T_Utilisateurs_Dim[EtatActivite]),
					T_Utilisateurs_Dim[TypeCompte] = "Technique",
					T_Utilisateurs_Dim[AccountEnabled] = FALSE()
				),
				0
			)
		formatString: 0
		lineageTag: 252cc12a-eaed-44ab-baa2-e5716d65883e

	measure NbBoitesActives =
			COALESCE(
				CALCULATE(
					COUNTROWS(T_Utilisateurs_Dim),
					REMOVEFILTERS(T_Utilisateurs_Dim[EtatActivite]),
					T_Utilisateurs_Dim[TypeCompte] = "Technique",
					T_Utilisateurs_Dim[AccountEnabled] = TRUE()
				),
				0
			)
		formatString: 0
		lineageTag: 721c0db6-9da2-4405-bf14-696a7a768841

	measure LicencesInactives =
			VAR _affectees = COALESCE([LicencesAffectees], 0)
			VAR _actives = COALESCE([LicencesActives], 0)
			RETURN
			MAX(0, _affectees - _actives)
		formatString: 0
		lineageTag: bc241cca-a9cb-4b23-aa44-116c69afe4a2

	measure LicencesActives =
			VAR _actives =
				CALCULATE(
					[LicencesAffectees],
					TREATAS(
						CALCULATETABLE(
							VALUES(T_Utilisateurs_Dim[UserPrincipalName]),
							FILTER(
								T_Utilisateurs_Dim,
								TRIM(T_Utilisateurs_Dim[EtatActivite]) = "Actif"
							)
						),
						T_Affectations_Fact[UserPrincipalName]
					)
				)
			RETURN
			COALESCE(_actives, 0)
		formatString: 0
		lineageTag: ebbf9efb-9959-4a33-85ae-9250badf11e9

	measure TauxActiviteUtilisateurs =
			VAR _baseActiveAD = MAX(0, [NbHumainsTotal] - [NbHumainsDesactives])
			RETURN
			DIVIDE([NbHumainsActifs], _baseActiveAD, 0)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 6eb920b2-fbc7-468e-8b0c-3c3bfec39bbc

	measure CiblesNettoyage =
			
			[NbHumainsInactifs] + [NbHumainsJamaisConnectes] + [NbHumainsDesactives] + [NbBoitesInactives]
		formatString: 0
		lineageTag: 1dff5eaa-1029-474e-b468-877e79b6be82

	measure LicencesComptesBloques =
			COALESCE(
				CALCULATE(
					[LicencesAffectees],
					REMOVEFILTERS(T_Utilisateurs_Dim[EtatActivite]),
					T_Utilisateurs_Dim[AccountEnabled] = FALSE()
				),
				0
			)
		formatString: 0
		lineageTag: d03af568-c222-4dbf-abdf-a3895f900095

	measure TauxGaspillage =
			
			DIVIDE([LicencesInactives], [LicencesAffectees], 0)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: c02aa7e8-e8fc-4b77-ad95-16d3640338e3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

