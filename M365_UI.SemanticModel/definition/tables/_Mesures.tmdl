	/// Score moyen d'utilisation par utilisateur distinct (dernier rapport)
	measure ScoreMoyenUtilisation =
			VAR DerniereDate = MAX(T_Activite_M365[DateRapport])
			RETURN
			CALCULATE(
			    AVERAGE(T_Activite_M365[ScoreUtilisation]),
			    T_Activite_M365[DateRapport] = DerniereDate
			)
		formatString: 0.00
		lineageTag: 130df3ab-7397-4e21-8f74-58940cbb6f92

		annotation PBI_FormatHint = {"isGeneralNumber":true}

