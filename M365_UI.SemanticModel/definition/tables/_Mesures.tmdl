	measure DT_EtatActivite =
			VAR _raw = SELECTEDVALUE(T_Utilisateurs_Dim[EtatActivite])
			VAR _enabled = SELECTEDVALUE(T_Utilisateurs_Dim[AccountEnabled])
			VAR _type = SELECTEDVALUE(T_Utilisateurs_Dim[TypeCompte])
			RETURN
			IF(
				NOT(ISBLANK(_raw)),
				_raw,
				IF(
					_enabled = FALSE(),
					"Desactive AD",
					IF(_type = "Technique", "Compte Technique", "-")
				)
			)
		displayFolder: Detail Utilisateur
