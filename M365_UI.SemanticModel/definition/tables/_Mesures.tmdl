	measure UsersAvecLesDeuxE3 =
			VAR UsersO365E3 =
				CALCULATETABLE(
					VALUES(T_Affectations_Fact[UserPrincipalName]),
					T_Affectations_Fact[CodeSKU] = "ENTERPRISEPACK"
				)
			VAR UsersM365E3 =
				CALCULATETABLE(
					VALUES(T_Affectations_Fact[UserPrincipalName]),
					T_Affectations_Fact[CodeSKU] = "SPE_E3"
				)
			RETURN
			COALESCE(COUNTROWS(INTERSECT(UsersO365E3, UsersM365E3)), 0)
		displayFolder: Audit Produits
		lineageTag: 6f15ea88-faa6-47ce-b2c6-57d9a3f73d84

		annotation SummarizationSetBy = Automatic

	measure DepassementCapacite =
			VAR _stock = COALESCE([StockLicences], 0)
			VAR _affectees = COALESCE([LicencesAffectees], 0)
			RETURN
			MAX(0, _affectees - _stock)
		formatString: 0
		lineageTag: 8f2559f8-3e06-4887-9bc7-f8013669d5c4

	measure DepassementCapaciteFlag = IF([LicencesDisponibles] < 0, 1, 0)
		formatString: 0
		lineageTag: 6ec4004a-9dfa-4adf-9ff6-c5bb0212f94f

	measure NiveauAlerteDisponibilite =
			VAR _scopeProduit = ISINSCOPE(T_Produits_Dim[NomProduit])
			VAR _stock = COALESCE([StockLicences], 0)
			VAR _dispo = COALESCE([LicencesDisponibles], 0)
			VAR _affectees = COALESCE([LicencesAffectees], 0)
			VAR _ratioDispo = DIVIDE(_dispo, _stock, 0)
			RETURN
			IF(
				NOT(_scopeProduit),
				0,
				SWITCH(
					TRUE(),
					(_stock = 0 && _affectees > 0) || _dispo < 0, 4,
					_ratioDispo <= 0.10, 3,
					_ratioDispo <= 0.25, 2,
					_ratioDispo <= 0.50, 1,
					0
				)
			)
		formatString: 0
		lineageTag: 86209fa6-45f3-4b7b-887a-c645422f8cc9

	measure UX_ContexteFiltres =
			VAR _produit = SELECTEDVALUE(T_Produits_Dim[NomProduit], "Tous")
			VAR _etat = SELECTEDVALUE(T_Utilisateurs_Dim[EtatActivite], "Tous")
			VAR _pays = SELECTEDVALUE(T_Utilisateurs_Dim[CountryOrRegion], "Tous")
			VAR _departement = SELECTEDVALUE(T_Utilisateurs_Dim[Department], "Tous")
			VAR _p = IF(LEN(_produit) > 24, LEFT(_produit, 24) & "...", _produit)
			VAR _e = IF(LEN(_etat) > 18, LEFT(_etat, 18) & "...", _etat)
			VAR _pa = IF(LEN(_pays) > 16, LEFT(_pays, 16) & "...", _pays)
			VAR _d = IF(LEN(_departement) > 16, LEFT(_departement, 16) & "...", _departement)
			RETURN
			"Filtres | Prod: " & _p
			& " | Etat: " & _e
			& " | Pays: " & _pa
			& " | Dept: " & _d
		displayFolder: UX
		lineageTag: ux-contexte-filtres-001

		annotation SummarizationSetBy = Automatic

	measure UX_DerniereMiseAJour =
			VAR _dateActivite = MAX(T_Activite_M365[DateRapport])
			VAR _dateUsers = MAX(T_Utilisateurs_Dim[WhenCreated])
			VAR _dateRef = COALESCE(_dateActivite, _dateUsers)
			RETURN
			"MAJ: " & IF(ISBLANK(_dateRef), "N/A", FORMAT(_dateRef, "yyyy-MM-dd"))
		displayFolder: UX
		lineageTag: ux-derniere-maj-001

		annotation SummarizationSetBy = Automatic

	measure UX_ProduitsEnDepassement =
			COALESCE(
				COUNTROWS(
					FILTER(
						VALUES(T_Produits_Dim[NomProduit]),
						[LicencesDisponibles] < 0
					)
				),
				0
			)
		formatString: 0
		displayFolder: UX
		lineageTag: ux-produits-depassement-001

		annotation SummarizationSetBy = Automatic

	measure UX_ProduitsStockEpuise =
			COALESCE(
				COUNTROWS(
					FILTER(
						VALUES(T_Produits_Dim[NomProduit]),
						[StockLicences] > 0
							&& [LicencesDisponibles] = 0
					)
				),
				0
			)
		formatString: 0
		displayFolder: UX
		lineageTag: ux-produits-stock-epuise-001

		annotation SummarizationSetBy = Automatic

	measure UX_ProduitsStockCritique =
			COALESCE(
				COUNTROWS(
					FILTER(
						VALUES(T_Produits_Dim[NomProduit]),
						VAR _stock = [StockLicences]
						VAR _dispo = [LicencesDisponibles]
						RETURN
							_stock > 0
								&& _dispo > 0
								&& DIVIDE(_dispo, _stock, 0) <= 0.10
					)
				),
				0
			)
		formatString: 0
		displayFolder: UX
		lineageTag: ux-produits-stock-critique-001

		annotation SummarizationSetBy = Automatic

	measure UX_NiveauRisqueLicences =
			VAR _depassement = [UX_ProduitsEnDepassement]
			VAR _epuise = [UX_ProduitsStockEpuise]
			VAR _critique = [UX_ProduitsStockCritique]
			RETURN
				SWITCH(
					TRUE(),
					_depassement > 0, "Critique",
					_epuise > 0 || _critique > 0, "A surveiller",
					"Stable"
				)
		displayFolder: UX
		lineageTag: ux-niveau-risque-licences-001

		annotation SummarizationSetBy = Automatic

	measure UX_BandeauRisqueLicences =
			VAR _depassement = [UX_ProduitsEnDepassement]
			VAR _epuise = [UX_ProduitsStockEpuise]
			VAR _critique = [UX_ProduitsStockCritique]
			RETURN
				"Priorite capacite | Depassement: " & FORMAT(_depassement, "0")
					& " | Stock epuise: " & FORMAT(_epuise, "0")
					& " | Critique <=10%: " & FORMAT(_critique, "0")
		displayFolder: UX
		lineageTag: ux-bandeau-risque-licences-001

		annotation SummarizationSetBy = Automatic

	measure DT_NiveauUtilisation =
			VAR _upnNorm = [DT_UPN_Courant]
			VAR _activiteUser =
				FILTER(
					ALL(T_Activite_M365),
					LOWER(TRIM(T_Activite_M365[UserPrincipalName])) = _upnNorm
				)
			VAR _dateRef =
				MAXX(
					FILTER(_activiteUser, NOT ISBLANK(T_Activite_M365[DateRapport])),
					T_Activite_M365[DateRapport]
				)
			VAR _ligneRecente =
				TOPN(
					1,
					FILTER(_activiteUser, T_Activite_M365[DateRapport] = _dateRef),
					T_Activite_M365[ScoreUtilisation], DESC,
					T_Activite_M365[NbAppsUtilisees], DESC
				)
			VAR _score = COALESCE(MAXX(_ligneRecente, T_Activite_M365[ScoreUtilisation]), 0)
			VAR _joursInactivite = MAXX(_ligneRecente, T_Activite_M365[JoursInactivite])
			RETURN
				IF(
					ISBLANK(_upnNorm),
					"-",
					SWITCH(
						TRUE(),
						ISBLANK(_dateRef), "Aucune donnee usage",
						NOT ISBLANK(_joursInactivite) && _joursInactivite > 90, "Inactif >90j",
						_score >= 7, "Intensif (7-10)",
						_score >= 4, "Standard (4-6)",
						_score >= 1, "Minimal (1-3)",
						"Aucun usage (0)"
					)
				)
		displayFolder: Detail Utilisateur
		lineageTag: dt-niveau-utilisation-001

		annotation SummarizationSetBy = Automatic

	measure DT_DateDerniereActivite =
			VAR _upnNorm = [DT_UPN_Courant]
			VAR _activiteUser =
				FILTER(
					ALL(T_Activite_M365),
					LOWER(TRIM(T_Activite_M365[UserPrincipalName])) = _upnNorm
				)
			VAR _dateActiviteApp =
				MAXX(
					FILTER(
						_activiteUser,
						NOT ISBLANK(T_Activite_M365[DateDerniereActivite])
							&& (
								COALESCE(T_Activite_M365[NbAppsUtilisees], 0) > 0
								|| COALESCE(T_Activite_M365[ScoreUtilisation], 0) > 0
							)
					),
					T_Activite_M365[DateDerniereActivite]
				)
			RETURN
				IF(
					ISBLANK(_upnNorm) || ISBLANK(_dateActiviteApp),
					"-",
					FORMAT(_dateActiviteApp, "yyyy-MM-dd")
				)
		displayFolder: Detail Utilisateur
		lineageTag: dt-date-derniere-activite-001

		annotation SummarizationSetBy = Automatic

	measure DT_ScoreUtilisation =
			VAR _upnNorm = [DT_UPN_Courant]
			VAR _activiteUser =
				FILTER(
					ALL(T_Activite_M365),
					LOWER(TRIM(T_Activite_M365[UserPrincipalName])) = _upnNorm
				)
			VAR _dateRef =
				MAXX(
					FILTER(_activiteUser, NOT ISBLANK(T_Activite_M365[DateRapport])),
					T_Activite_M365[DateRapport]
				)
			VAR _ligneRecente =
				TOPN(
					1,
					FILTER(_activiteUser, T_Activite_M365[DateRapport] = _dateRef),
					T_Activite_M365[ScoreUtilisation], DESC,
					T_Activite_M365[NbAppsUtilisees], DESC
				)
			VAR _score = MAXX(_ligneRecente, T_Activite_M365[ScoreUtilisation])
			RETURN
				IF(ISBLANK(_upnNorm), 0, COALESCE(_score, 0))
		formatString: 0
		displayFolder: Detail Utilisateur
		lineageTag: dt-score-utilisation-001

		annotation SummarizationSetBy = Automatic

	measure DT_NbAppsUtilisees =
			VAR _upnNorm = [DT_UPN_Courant]
			VAR _activiteUser =
				FILTER(
					ALL(T_Activite_M365),
					LOWER(TRIM(T_Activite_M365[UserPrincipalName])) = _upnNorm
				)
			VAR _dateRef =
				MAXX(
					FILTER(_activiteUser, NOT ISBLANK(T_Activite_M365[DateRapport])),
					T_Activite_M365[DateRapport]
				)
			VAR _ligneRecente =
				TOPN(
					1,
					FILTER(_activiteUser, T_Activite_M365[DateRapport] = _dateRef),
					T_Activite_M365[NbAppsUtilisees], DESC,
					T_Activite_M365[ScoreUtilisation], DESC
				)
			VAR _nbApps = MAXX(_ligneRecente, T_Activite_M365[NbAppsUtilisees])
			RETURN
				IF(ISBLANK(_upnNorm), 0, COALESCE(_nbApps, 0))
		formatString: 0
		displayFolder: Detail Utilisateur
		lineageTag: dt-nb-apps-utilisees-001

		annotation SummarizationSetBy = Automatic

	measure DT_UPN_Courant =
			VAR _upnFromUser = SELECTEDVALUE(T_Utilisateurs_Dim[UserPrincipalName])
			VAR _displayName = SELECTEDVALUE(T_Utilisateurs_Dim[DisplayName])
			VAR _upnFromDisplay =
				IF(
					NOT ISBLANK(_displayName),
					CALCULATE(
						MIN(T_Utilisateurs_Dim[UserPrincipalName]),
						FILTER(
							ALL(T_Utilisateurs_Dim),
							T_Utilisateurs_Dim[DisplayName] = _displayName
						)
					)
				)
			VAR _upnFromAffectation = SELECTEDVALUE(T_Affectations_Fact[UserPrincipalName])
			VAR _upnFromActivite = SELECTEDVALUE(T_Activite_M365[UserPrincipalName])
			VAR _upnFinal = COALESCE(_upnFromUser, _upnFromDisplay, _upnFromAffectation, _upnFromActivite)
			RETURN
				IF(ISBLANK(_upnFinal), BLANK(), LOWER(TRIM(_upnFinal)))
		displayFolder: Detail Utilisateur
		lineageTag: dt-upn-courant-001

		annotation SummarizationSetBy = Automatic

	measure DT_DateDerniereAuthentification =
			VAR _upnNorm = [DT_UPN_Courant]
			VAR _dateAuth =
				MAXX(
					FILTER(
						ALL(T_Utilisateurs_Dim),
						LOWER(TRIM(T_Utilisateurs_Dim[UserPrincipalName])) = _upnNorm
					),
					T_Utilisateurs_Dim[LastSignIn]
				)
			RETURN
				IF(
					ISBLANK(_upnNorm) || ISBLANK(_dateAuth),
					"-",
					FORMAT(_dateAuth, "yyyy-MM-dd HH:mm")
				)
		displayFolder: Detail Utilisateur
		lineageTag: dt-date-derniere-auth-001

		annotation SummarizationSetBy = Automatic

	measure NomUtilisateurAffiche =
			VAR _nom = SELECTEDVALUE(T_Utilisateurs_Dim[DisplayNameAffiche])
			VAR _upnDim = SELECTEDVALUE(T_Utilisateurs_Dim[UserPrincipalName])
			VAR _upnFact = SELECTEDVALUE(T_Affectations_Fact[UserPrincipalName])
			RETURN
			COALESCE(_nom, _upnDim, _upnFact, "(Utilisateur non mappe)")
		lineageTag: 00cd6ceb-8ead-4938-a716-3cc5ee00baf5

	measure FlagLigneCompteDesactive =
			VAR _upn =
				COALESCE(
					SELECTEDVALUE(T_Utilisateurs_Dim[UserPrincipalName]),
					SELECTEDVALUE(T_Affectations_Fact[UserPrincipalName])
				)
			VAR _isDisabled =
				COALESCE(SELECTEDVALUE(T_Utilisateurs_Dim[AccountEnabled]), TRUE()) = FALSE()
			VAR _hasLicence = [LicencesAffectees] > 0
			RETURN
			IF(NOT ISBLANK(_upn) && _isDisabled && _hasLicence, 1, 0)
		formatString: 0
		lineageTag: 81b1022e-6396-4ac2-bdab-c6da8fc6e0d9

	/// ============================================================
	/// B1 — Mesures pour page Detail Produit (drill-through)
	/// ============================================================
	/// Nombre d'utilisateurs affectes a un produit donne
	measure DT_Produit_NbUtilisateurs = DISTINCTCOUNT(T_Affectations_Fact[UserPrincipalName])
		formatString: 0
		displayFolder: Detail Produit
		lineageTag: dt-produit-nb-utilisateurs-001

		annotation SummarizationSetBy = Automatic

	/// Taux de remplissage d'un produit (affectes / stock)
	measure DT_Produit_TauxRemplissage =
			VAR _stock = SELECTEDVALUE(T_Produits_Dim[TotalUnits])
			VAR _affectes = DISTINCTCOUNT(T_Affectations_Fact[UserPrincipalName])
			RETURN
				IF(ISBLANK(_stock) || _stock = 0, 0, DIVIDE(_affectes, _stock, 0))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Detail Produit
		lineageTag: dt-produit-taux-remplissage-001

		annotation SummarizationSetBy = Automatic

	/// Marge restante sur un produit
	measure DT_Produit_MargeRestante =
			VAR _stock = COALESCE(SELECTEDVALUE(T_Produits_Dim[TotalUnits]), 0)
			VAR _affectes = DISTINCTCOUNT(T_Affectations_Fact[UserPrincipalName])
			RETURN
				_stock - _affectes
		formatString: 0
		displayFolder: Detail Produit
		lineageTag: dt-produit-marge-restante-001

		annotation SummarizationSetBy = Automatic

	/// ============================================================
	/// B2 — Mesures pour historique activite utilisateur
	/// ============================================================
	/// Score utilisation par date de rapport (pour line chart temporel)
	measure DT_Historique_Score =
			VAR _upnNorm = [DT_UPN_Courant]
			RETURN
				IF(
					ISBLANK(_upnNorm),
					BLANK(),
					CALCULATE(
						AVERAGE(T_Activite_M365[ScoreUtilisation]),
						FILTER(
							ALL(T_Activite_M365),
							LOWER(TRIM(T_Activite_M365[UserPrincipalName])) = _upnNorm
						)
					)
				)
		formatString: 0.0
		displayFolder: Detail Utilisateur
		lineageTag: dt-historique-score-001

		annotation SummarizationSetBy = Automatic

	/// Nombre d'apps par date de rapport (pour line chart temporel)
	measure DT_Historique_NbApps =
			VAR _upnNorm = [DT_UPN_Courant]
			RETURN
				IF(
					ISBLANK(_upnNorm),
					BLANK(),
					CALCULATE(
						AVERAGE(T_Activite_M365[NbAppsUtilisees]),
						FILTER(
							ALL(T_Activite_M365),
							LOWER(TRIM(T_Activite_M365[UserPrincipalName])) = _upnNorm
						)
					)
				)
		formatString: 0
		displayFolder: Detail Utilisateur
		lineageTag: dt-historique-nbapps-001

		annotation SummarizationSetBy = Automatic

