	measure DT_DiagnosticClassification =
			VAR _typeCompte = COALESCE(SELECTEDVALUE(T_Utilisateurs_Dim[TypeCompte]), "-")
			VAR _regle = COALESCE(SELECTEDVALUE(T_Utilisateurs_Dim[RegleTypeCompte]), "-")
			RETURN
			"Diagnostic | TypeCompte=" & _typeCompte
			& " | Regle=" & _regle
			& " | Activite M365: decalage structurel 48-72h"
		displayFolder: Detail Utilisateur
		lineageTag: dt-diagnostic-classification-001

		annotation SummarizationSetBy = Automatic

	measure UX_QualiteDonnees =
			VAR _nonDefinis =
				CALCULATE(
					COUNTROWS(T_Utilisateurs_Dim),
					REMOVEFILTERS(T_Utilisateurs_Dim),
					REMOVEFILTERS(T_Produits_Dim),
					REMOVEFILTERS(T_Affectations_Fact),
					REMOVEFILTERS(T_Activite_M365),
					T_Utilisateurs_Dim[TypeCompte] = "Non defini"
				)
			VAR _nonSynchronises =
				CALCULATE(
					COUNTROWS(T_Utilisateurs_Dim),
					REMOVEFILTERS(T_Utilisateurs_Dim),
					REMOVEFILTERS(T_Produits_Dim),
					REMOVEFILTERS(T_Affectations_Fact),
					REMOVEFILTERS(T_Activite_M365),
					ISBLANK(T_Utilisateurs_Dim[AccountEnabled])
				)
			VAR _nonClasses =
				CALCULATE(
					[NbLignesNonClassifiees],
					REMOVEFILTERS(T_Utilisateurs_Dim),
					REMOVEFILTERS(T_Produits_Dim),
					REMOVEFILTERS(T_Affectations_Fact),
					REMOVEFILTERS(T_Activite_M365)
				)
			VAR _alertes = COALESCE(_nonDefinis, 0) + COALESCE(_nonSynchronises, 0) + COALESCE(_nonClasses, 0)
			RETURN
			IF(
				_alertes = 0,
				"DQ OK",
				"DQ ND:" & FORMAT(COALESCE(_nonDefinis, 0), "0")
				& " NS:" & FORMAT(COALESCE(_nonSynchronises, 0), "0")
				& " NC:" & FORMAT(COALESCE(_nonClasses, 0), "0")
			)
		displayFolder: UX
		lineageTag: ux-qualite-donnees-001

		annotation SummarizationSetBy = Automatic

