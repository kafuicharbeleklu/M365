	measure NbComptesDesactivesAvecLicence =
			VAR _isProductScoped = ISCROSSFILTERED(T_Produits_Dim)
			VAR _base =
				CALCULATE(
					DISTINCTCOUNT(T_Utilisateurs_Dim[UserPrincipalName]),
					REMOVEFILTERS(T_Utilisateurs_Dim[EtatActivite]),
					T_Utilisateurs_Dim[AccountEnabled] = FALSE(),
					T_Utilisateurs_Dim[StatutLicence] = "ON"
				)
			VAR _scoped =
				CALCULATE(
					DISTINCTCOUNT(T_Utilisateurs_Dim[UserPrincipalName]),
					REMOVEFILTERS(T_Utilisateurs_Dim[EtatActivite]),
					T_Utilisateurs_Dim[AccountEnabled] = FALSE(),
					T_Utilisateurs_Dim[StatutLicence] = "ON",
					KEEPFILTERS(
						TREATAS(
							VALUES(T_Affectations_Fact[UserPrincipalName]),
							T_Utilisateurs_Dim[UserPrincipalName]
						)
					)
				)
			RETURN
				COALESCE(IF(_isProductScoped, _scoped, _base), 0)
		formatString: 0
		displayFolder: Utilisateurs
		lineageTag: 47ef3f5b-7db6-455d-b8b3-bf4f7a1f35d2

	measure UX_ParametresActifs =
			VAR _seuilInactivite = FORMAT(MAX(T_Parametres_Dim[SeuilInactiviteJours]), "0")
			VAR _seuilCritique = FORMAT(MAX(T_Parametres_Dim[SeuilStockCritiquePct]), "0")
			VAR _seuilAlerte = FORMAT(MAX(T_Parametres_Dim[SeuilStockAlertePct]), "0")
			VAR _seuilSurveillance = FORMAT(MAX(T_Parametres_Dim[SeuilStockSurveillancePct]), "0")
			VAR _periodeRaw = COALESCE(MAX(T_Parametres_Dim[PeriodeActivite]), "N/A")
			VAR _periodeAffichee =
				IF(
					LEFT(_periodeRaw, 1) = "D" && LEN(_periodeRaw) > 1,
					MID(_periodeRaw, 2, LEN(_periodeRaw) - 1) & "j",
					_periodeRaw
				)
			RETURN
			"Param | Inact>" & _seuilInactivite & "j"
			& " | Stock " & _seuilCritique & "/" & _seuilAlerte & "/" & _seuilSurveillance & "%"
			& " | Activite " & _periodeAffichee
			& " | " & [UX_QualiteDonnees]
		displayFolder: UX
		lineageTag: ux-parametres-actifs-001

		annotation SummarizationSetBy = Automatic

	measure FlagLigneActiviteSousLicence =
			VAR _upn =
				COALESCE(
					SELECTEDVALUE(T_Utilisateurs_Dim[UserPrincipalName]),
					SELECTEDVALUE(T_Affectations_Fact[UserPrincipalName])
				)
			VAR _isDisabled =
				COALESCE(SELECTEDVALUE(T_Utilisateurs_Dim[AccountEnabled]), TRUE()) = FALSE()
			VAR _hasLicence = [LicencesAffectees] > 0
			VAR _codeEtat = SELECTEDVALUE(T_Utilisateurs_Dim[CodeEtatActivite])
			RETURN
			SWITCH(
				TRUE(),
				ISBLANK(_upn) || NOT _hasLicence || _isDisabled, 0,
				_codeEtat = "JAMAIS_CONNECTE", 2,
				_codeEtat IN {"INACTIF", "INACTIF_M365"}, 1,
				0
			)
		formatString: 0
		displayFolder: Diagnostic
		lineageTag: 9f4f4cb0-625e-4f90-a3cc-f7394a853208

	measure LicencesConsommeesTableau =
			VAR _affectees = [LicencesAffectees]
			RETURN
				IF(COALESCE(_affectees, 0) > 0, _affectees, BLANK())
		formatString: 0
		displayFolder: Licences
		lineageTag: e421730b-f38f-4dfa-8a5f-5ce08e5dc7bf

