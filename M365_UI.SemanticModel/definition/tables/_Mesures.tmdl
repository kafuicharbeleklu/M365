	measure DT_EtatActivite =
			VAR _raw = SELECTEDVALUE(T_Utilisateurs_Dim[EtatActivite])
			VAR _enabled = SELECTEDVALUE(T_Utilisateurs_Dim[AccountEnabled])
			VAR _type = SELECTEDVALUE(T_Utilisateurs_Dim[TypeCompte])
			RETURN
			IF(
				NOT(ISBLANK(_raw)),
				_raw,
				IF(
					_enabled = FALSE(),
					"Desactive AD",
					IF(_type = "Technique", "Compte Technique", "-")
				)
			)
		displayFolder: Detail Utilisateur
		lineageTag: dt-etat-v42-001

		annotation SummarizationSetBy = Automatic

	measure NbInactifsM365 =
			VAR _isProductScoped = ISCROSSFILTERED(T_Produits_Dim)
			VAR _base =
				CALCULATE(
					DISTINCTCOUNT(T_Utilisateurs_Dim[UserPrincipalName]),
					FILTER(
						T_Utilisateurs_Dim,
						TRIM(T_Utilisateurs_Dim[EtatActivite]) = "Inactif M365"
					)
				)
			VAR _scoped =
				CALCULATE(
					DISTINCTCOUNT(T_Utilisateurs_Dim[UserPrincipalName]),
					FILTER(
						T_Utilisateurs_Dim,
						TRIM(T_Utilisateurs_Dim[EtatActivite]) = "Inactif M365"
					),
					KEEPFILTERS(
						TREATAS(
							VALUES(T_Affectations_Fact[UserPrincipalName]),
							T_Utilisateurs_Dim[UserPrincipalName]
						)
					)
				)
			RETURN
				COALESCE(IF(_isProductScoped, _scoped, _base), 0)
		displayFolder: Utilisateurs
		lineageTag: nb-inactifs-m365-001

		annotation SummarizationSetBy = Automatic

