	measure TT_p3_fantomes_lect =
			VAR _periodeRaw = MAX(T_Parametres_Dim[PeriodeActivite])
			VAR _periodeLibelle =
				IF(
					LEFT(_periodeRaw, 1) = "D",
					MID(_periodeRaw, 2, LEN(_periodeRaw) - 1) & " derniers jours",
					_periodeRaw
				)
			RETURN
			"Utilisateurs dont le compte Azure AD est actif mais qui n'apparaissent dans aucune donnée d'activité Microsoft 365 sur les "
			& _periodeLibelle
			& ". Distinct des utilisateurs jamais connectés à AD."
		displayFolder: Tooltips
		lineageTag: tt-p3-fantomes-lect

		annotation SummarizationSetBy = Automatic

