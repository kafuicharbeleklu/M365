		formatString: 0
		lineageTag: 252cc12a-eaed-44ab-baa2-e5716d65883e

	measure NbBoitesActives =
			COALESCE(
				CALCULATE(
					COUNTROWS(T_Utilisateurs_Dim),
					REMOVEFILTERS(T_Utilisateurs_Dim[EtatActivite]),
