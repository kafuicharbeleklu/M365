	/// Total comptes humains (TypeCompte = "Utilisateur"), toutes catégories.
	/// Exclut les comptes techniques (EtatActivite = BLANK pour ceux-ci).
	measure NbHumainsTotal =
			COALESCE(
				[NbHumainsActifs]
				+ [NbHumainsInactifs]
				+ [NbHumainsJamaisConnectes]
				+ [NbInactifsM365]
				+ [NbHumainsDesactives],
				0
			)
		formatString: 0
		displayFolder: Utilisateurs
		lineageTag: e14dc89f-4a3b-4283-94e2-021e753627a5

	measure NbHumainsActifs =
			VAR _isProductScoped = ISCROSSFILTERED(T_Produits_Dim)
			VAR _base =
				CALCULATE(
					DISTINCTCOUNT(T_Utilisateurs_Dim[UserPrincipalName]),
					FILTER(
						T_Utilisateurs_Dim,
						T_Utilisateurs_Dim[CodeEtatActivite] = "ACTIF"
					)
				)
			VAR _scoped =
				CALCULATE(
					DISTINCTCOUNT(T_Utilisateurs_Dim[UserPrincipalName]),
					FILTER(
						T_Utilisateurs_Dim,
						T_Utilisateurs_Dim[CodeEtatActivite] = "ACTIF"
					),
					KEEPFILTERS(
						TREATAS(
							VALUES(T_Affectations_Fact[UserPrincipalName]),
							T_Utilisateurs_Dim[UserPrincipalName]
						)
					)
				)
			RETURN
				COALESCE(IF(_isProductScoped, _scoped, _base), 0)
		formatString: 0
		displayFolder: Utilisateurs
		lineageTag: e7698b1d-b19f-4138-a8e2-e7447d74d67b

	measure NbHumainsInactifs =
			VAR _isProductScoped = ISCROSSFILTERED(T_Produits_Dim)
