		annotation SummarizationSetBy = Automatic

	measure TT_p3_fantomes_lect_clean =
			VAR _periodeRaw = MAX(T_Parametres_Dim[PeriodeActivite])
			VAR _periodeLibelle =
				IF(
					LEFT(_periodeRaw, 1) = "D",
					MID(_periodeRaw, 2, LEN(_periodeRaw) - 1) & " derniers jours",
					_periodeRaw
				)
			RETURN
			"Actifs dans AD mais absents des donnees M365 sur les "
			& _periodeLibelle
			& ". A distinguer des jamais connectes."
		displayFolder: Tooltips
		lineageTag: tt-p3-fantomes-lect-clean

		annotation SummarizationSetBy = Automatic

