	measure UX_ProduitsStockEpuise =
			COALESCE(
				COUNTROWS(
					FILTER(
						VALUES(T_Produits_Dim[NomProduit]),
						[StockLicences] > 0
							&& [LicencesDisponibles] = 0
					)
				),
				0
			)
		formatString: 0
		displayFolder: UX
		lineageTag: ux-produits-stock-epuise-001

		annotation SummarizationSetBy = Automatic

	measure UX_ProduitsStockCritique =
			COALESCE(
				COUNTROWS(
					FILTER(
						VALUES(T_Produits_Dim[NomProduit]),
						VAR _stock = [StockLicences]
						VAR _dispo = [LicencesDisponibles]
						VAR _seuilCritique =
							DIVIDE(MAX(T_Parametres_Dim[SeuilStockCritiquePct]), 100, 0)
						RETURN
							_stock > 0
								&& _dispo > 0
								&& DIVIDE(_dispo, _stock, 0) <= _seuilCritique
					)
				),
				0
			)
		formatString: 0
		displayFolder: UX
		lineageTag: ux-produits-stock-critique-001

		annotation SummarizationSetBy = Automatic

	measure UX_NiveauRisqueLicences =
			VAR _depassement = [UX_ProduitsEnDepassement]
			VAR _epuise = [UX_ProduitsStockEpuise]
			VAR _critique = [UX_ProduitsStockCritique]
			RETURN
				SWITCH(
					TRUE(),
					_depassement > 0, "Critique",
					_epuise > 0 || _critique > 0, "A surveiller",
					"Stable"
				)
		displayFolder: UX
		lineageTag: ux-niveau-risque-licences-001

		annotation SummarizationSetBy = Automatic

	measure DT_NiveauUtilisation =
			VAR _upnNorm = [DT_UPN_Courant]
			VAR _seuilInactiviteJours =
				MAX(T_Parametres_Dim[SeuilInactiviteJours])
			VAR _scoreBandPowerUser =
				MAX(T_Parametres_Dim[ScoreBandPowerUser])
			VAR _scoreBandStandard =
				MAX(T_Parametres_Dim[ScoreBandStandard])
			VAR _scoreBandMinimal =
				MAX(T_Parametres_Dim[ScoreBandMinimal])
			VAR _labelInactif =
				"Inactif >" & FORMAT(_seuilInactiviteJours, "0") & "j"
			VAR _labelPowerUser =
				"Intensif (" & FORMAT(_scoreBandPowerUser, "0") & "-10)"
			VAR _labelStandard =
				"Standard (" & FORMAT(_scoreBandStandard, "0") & "-" & FORMAT(_scoreBandPowerUser - 1, "0") & ")"
			VAR _labelMinimal =
				"Minimal (" & FORMAT(_scoreBandMinimal, "0") & "-" & FORMAT(_scoreBandStandard - 1, "0") & ")"
			VAR _activiteUser =
				FILTER(
					ALL(T_Activite_M365),
					LOWER(TRIM(T_Activite_M365[UserPrincipalName])) = _upnNorm
				)
			VAR _dateRef =
				MAXX(
					FILTER(_activiteUser, NOT ISBLANK(T_Activite_M365[DateRapport])),
					T_Activite_M365[DateRapport]
				)
			VAR _ligneRecente =
				TOPN(
					1,
					FILTER(_activiteUser, T_Activite_M365[DateRapport] = _dateRef),
					T_Activite_M365[ScoreUtilisation], DESC,
					T_Activite_M365[NbAppsUtilisees], DESC
				)
			VAR _score = COALESCE(MAXX(_ligneRecente, T_Activite_M365[ScoreUtilisation]), 0)
			VAR _joursInactivite = MAXX(_ligneRecente, T_Activite_M365[JoursInactivite])
			RETURN
				IF(
					ISBLANK(_upnNorm),
					"-",
					SWITCH(
						TRUE(),
						ISBLANK(_dateRef), "Aucune donnee usage",
						NOT ISBLANK(_joursInactivite) && _joursInactivite > _seuilInactiviteJours, _labelInactif,
						_score >= _scoreBandPowerUser, _labelPowerUser,
						_score >= _scoreBandStandard, _labelStandard,
						_score >= _scoreBandMinimal, _labelMinimal,
						"Aucun usage (0)"
					)
				)
		displayFolder: Detail Utilisateur
		lineageTag: dt-niveau-utilisation-001

		annotation SummarizationSetBy = Automatic

	measure DT_DateDerniereActivite =
			VAR _upnNorm = [DT_UPN_Courant]
			VAR _activiteUser =
				FILTER(
					ALL(T_Activite_M365),
					LOWER(TRIM(T_Activite_M365[UserPrincipalName])) = _upnNorm
				)
			VAR _dateActiviteApp =
				MAXX(
					FILTER(
						_activiteUser,
						NOT ISBLANK(T_Activite_M365[DateDerniereActivite])
							&& (
								COALESCE(T_Activite_M365[NbAppsUtilisees], 0) > 0
								|| COALESCE(T_Activite_M365[ScoreUtilisation], 0) > 0
							)
					),
					T_Activite_M365[DateDerniereActivite]
				)
			RETURN
				IF(
					ISBLANK(_upnNorm) || ISBLANK(_dateActiviteApp),
					"-",
					FORMAT(_dateActiviteApp, "yyyy-MM-dd")
				)
		displayFolder: Detail Utilisateur
		lineageTag: dt-date-derniere-activite-001

		annotation SummarizationSetBy = Automatic

	measure DT_ScoreUtilisation =
			VAR _upnNorm = [DT_UPN_Courant]
			VAR _activiteUser =
				FILTER(
					ALL(T_Activite_M365),
					LOWER(TRIM(T_Activite_M365[UserPrincipalName])) = _upnNorm
				)
			VAR _dateRef =
				MAXX(
					FILTER(_activiteUser, NOT ISBLANK(T_Activite_M365[DateRapport])),
					T_Activite_M365[DateRapport]
				)
			VAR _ligneRecente =
				TOPN(
					1,
					FILTER(_activiteUser, T_Activite_M365[DateRapport] = _dateRef),
					T_Activite_M365[ScoreUtilisation], DESC,
					T_Activite_M365[NbAppsUtilisees], DESC
				)
			VAR _score = MAXX(_ligneRecente, T_Activite_M365[ScoreUtilisation])
			RETURN
				IF(ISBLANK(_upnNorm), 0, COALESCE(_score, 0))
		formatString: 0
		displayFolder: Detail Utilisateur
		lineageTag: dt-score-utilisation-001

		annotation SummarizationSetBy = Automatic

	measure DT_NbAppsUtilisees =
			VAR _upnNorm = [DT_UPN_Courant]
			VAR _activiteUser =
				FILTER(
					ALL(T_Activite_M365),
					LOWER(TRIM(T_Activite_M365[UserPrincipalName])) = _upnNorm
				)
			VAR _dateRef =
				MAXX(
					FILTER(_activiteUser, NOT ISBLANK(T_Activite_M365[DateRapport])),
					T_Activite_M365[DateRapport]
				)
			VAR _ligneRecente =
				TOPN(
					1,
					FILTER(_activiteUser, T_Activite_M365[DateRapport] = _dateRef),
					T_Activite_M365[NbAppsUtilisees], DESC,
					T_Activite_M365[ScoreUtilisation], DESC
				)
			VAR _nbApps = MAXX(_ligneRecente, T_Activite_M365[NbAppsUtilisees])
			RETURN
				IF(ISBLANK(_upnNorm), 0, COALESCE(_nbApps, 0))
		formatString: 0
		displayFolder: Detail Utilisateur
		lineageTag: dt-nb-apps-utilisees-001

		annotation SummarizationSetBy = Automatic

	measure DT_UPN_Courant =
			VAR _upnFromUser = SELECTEDVALUE(T_Utilisateurs_Dim[UserPrincipalName])
			VAR _displayName = SELECTEDVALUE(T_Utilisateurs_Dim[DisplayName])
			VAR _upnFromDisplay =
				IF(
					NOT ISBLANK(_displayName),
					CALCULATE(
						MIN(T_Utilisateurs_Dim[UserPrincipalName]),
						FILTER(
							ALL(T_Utilisateurs_Dim),
							T_Utilisateurs_Dim[DisplayName] = _displayName
						)
					)
				)
			VAR _upnFromAffectation = SELECTEDVALUE(T_Affectations_Fact[UserPrincipalName])
			VAR _upnFromActivite = SELECTEDVALUE(T_Activite_M365[UserPrincipalName])
			VAR _upnFinal = COALESCE(_upnFromUser, _upnFromDisplay, _upnFromAffectation, _upnFromActivite)
			RETURN
				IF(ISBLANK(_upnFinal), BLANK(), LOWER(TRIM(_upnFinal)))
		displayFolder: Detail Utilisateur
		lineageTag: dt-upn-courant-001

		annotation SummarizationSetBy = Automatic

	measure DT_DateDerniereAuthentification =
			VAR _upnNorm = [DT_UPN_Courant]
			VAR _dateAuth =
				MAXX(
					FILTER(
						ALL(T_Utilisateurs_Dim),
						LOWER(TRIM(T_Utilisateurs_Dim[UserPrincipalName])) = _upnNorm
					),
					T_Utilisateurs_Dim[LastSignIn]
				)
			RETURN
				IF(
					ISBLANK(_upnNorm) || ISBLANK(_dateAuth),
					"-",
					FORMAT(_dateAuth, "yyyy-MM-dd HH:mm")
				)
		displayFolder: Detail Utilisateur
		lineageTag: dt-date-derniere-auth-001

		annotation SummarizationSetBy = Automatic

	measure NomUtilisateurAffiche =
			VAR _nom = SELECTEDVALUE(T_Utilisateurs_Dim[DisplayNameAffiche])
			VAR _upnDim = SELECTEDVALUE(T_Utilisateurs_Dim[UserPrincipalName])
			VAR _upnFact = SELECTEDVALUE(T_Affectations_Fact[UserPrincipalName])
			RETURN
			COALESCE(_nom, _upnDim, _upnFact, "(Utilisateur non mappe)")
		displayFolder: Utilisateurs
		lineageTag: 00cd6ceb-8ead-4938-a716-3cc5ee00baf5

	measure FlagLigneCompteDesactive =
			VAR _upn =
				COALESCE(
					SELECTEDVALUE(T_Utilisateurs_Dim[UserPrincipalName]),
					SELECTEDVALUE(T_Affectations_Fact[UserPrincipalName])
				)
			VAR _isDisabled =
				COALESCE(SELECTEDVALUE(T_Utilisateurs_Dim[AccountEnabled]), TRUE()) = FALSE()
			VAR _hasLicence = [LicencesAffectees] > 0
			RETURN
			IF(NOT ISBLANK(_upn) && _isDisabled && _hasLicence, 1, 0)
		formatString: 0
		displayFolder: Diagnostic
		lineageTag: 81b1022e-6396-4ac2-bdab-c6da8fc6e0d9

