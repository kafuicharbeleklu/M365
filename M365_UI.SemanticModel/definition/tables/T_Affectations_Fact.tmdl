				        Source, 
				        {"UserPrincipalName", "Licences_Brutes"}
				    ),
				    
				    // ═══════════════════════════════════════════════════════════════════
				    // 2. EXPLOSION DES LICENCES
				    // ═══════════════════════════════════════════════════════════════════
