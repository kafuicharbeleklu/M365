				        #"Colonnes sélectionnées", 
				        "Licences_Brutes"
				    ),
				    
				    #"Lignes filtrées" = Table.SelectRows(
				        #"Expanded Licences", 
				        each [Licences_Brutes] <> null
				    ),
				    
				    #"Expanded Record" = Table.ExpandRecordColumn(
				        #"Lignes filtrées", 
				        "Licences_Brutes", 
				        {"skuId"}, 
				        {"skuId"}
				    ),
				    
				    // ═══════════════════════════════════════════════════════════════════
				    // 3. JOINTURE AVEC T_PRODUITS_DIM (Sur skuId)
				    // ═══════════════════════════════════════════════════════════════════
				    #"Requêtes fusionnées" = Table.NestedJoin(
				        #"Expanded Record", 
				        {"skuId"}, 
				        T_Produits_Dim, 
				        {"skuId"}, 
				        "T_Produits_Dim", 
				        JoinKind.LeftOuter
				    ),
				    
				    // Récupérer NomProduit ET TypeLicence
				    #"Expanded Produits" = Table.ExpandTableColumn(
				        #"Requêtes fusionnées", 
				        "T_Produits_Dim", 
				        {"CodeSKU", "NomProduit", "TypeLicence"}, 
				        {"CodeSKU", "NomProduit", "TypeLicence"}
				    ),
				    
				    // ═══════════════════════════════════════════════════════════════════
				    // 4. NETTOYAGE
				    // ═══════════════════════════════════════════════════════════════════
				    #"Colonnes supprimées" = Table.RemoveColumns(
				        #"Expanded Produits", 
				        {"skuId"}
				    ),
				    
				    // Supprimer les doublons
				    #"Doublons supprimés" = Table.Distinct(#"Colonnes supprimées"),
				    
				    // ═══════════════════════════════════════════════════════════════════
				    // 5. INDEX UNIQUE
				    // ═══════════════════════════════════════════════════════════════════
				    #"Index ajouté" = Table.AddIndexColumn(
				        #"Doublons supprimés", 
				        "AffectationID", 
				        1, 
				        1, 
				        Int64.Type
				    ),
				    
				    // ═══════════════════════════════════════════════════════════════════
				    // 6. RÉORGANISATION
				    // ═══════════════════════════════════════════════════════════════════
				    #"Colonnes réorganisées" = Table.ReorderColumns(
				        #"Index ajouté", 
				        {"AffectationID", "UserPrincipalName", "CodeSKU", "NomProduit", "TypeLicence"}
				    )
				
				in
				    #"Colonnes réorganisées"
				```

