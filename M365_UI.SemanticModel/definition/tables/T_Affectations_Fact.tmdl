	partition T_Affectations_Fact = m
		mode: import
		source = ```
				let
				    Source = T_Utilisateurs_Dim,
				    
				    // ═══════════════════════════════════════════════════════════════════
				    // 1. SÉLECTION DES COLONNES
				    // ═══════════════════════════════════════════════════════════════════
