	partition T_Utilisateurs_Dim = m
		mode: import
		source = ```
				let
				    // ═══════════════════════════════════════════════════════════════════
				    // 1. AUTHENTIFICATION SÉCURISÉE (Via Paramètres)
				    // ═══════════════════════════════════════════════════════════════════
				    TenantId = Text.From(#"Param_TenantId"),
				    ClientId = Text.From(#"Param_ClientId"),
				    ClientSecret = Text.From(#"Param_Secret"),
				
				    GetAccessToken = () =>
				        let
				            Url = "https://login.microsoftonline.com/" & TenantId & "/oauth2/v2.0/token",
				            Body = "client_id=" & ClientId & 
				                   "&scope=https://graph.microsoft.com/.default" & 
				                   "&client_secret=" & Uri.EscapeDataString(ClientSecret) & 
				                   "&grant_type=client_credentials",
				            Response = Json.Document(
				                Web.Contents(Url, [
				                    Headers = [#"Content-Type" = "application/x-www-form-urlencoded"], 
				                    Content = Text.ToBinary(Body)
				                ])
				            ),
				            Token = "Bearer " & Response[access_token]
				        in
				            Token,
				
				    AuthToken = GetAccessToken(),
				
				    // ═══════════════════════════════════════════════════════════════════
				    // 2. URL CIBLE (API BETA pour signInActivity)
				    // ═══════════════════════════════════════════════════════════════════
				    BaseUrl = "https://graph.microsoft.com/beta/users?" 
				              & "$top=999&" 
				              & "$select=id,displayName,userPrincipalName,department,country,"
				              & "usageLocation,userType,accountEnabled,assignedLicenses,createdDateTime,signInActivity",
				
				    // ═══════════════════════════════════════════════════════════════════
				    // 3. PAGINATION
				    // ═══════════════════════════════════════════════════════════════════
				    FetchPage = (url) =>
				        let
				            RawData = Json.Document(Web.Contents(url, [Headers = [Authorization = AuthToken]])),
				            NextLink = try RawData[#"@odata.nextLink"] otherwise null,
				            Data = try RawData[value] otherwise null
				        in
				            [Data = Data, Next = NextLink],
				
				    AllPages = List.Generate(
				        () => FetchPage(BaseUrl),
				        each [Data] <> null,
				        each FetchPage([Next]),
				        each [Data]
				    ),
				
				    // ═══════════════════════════════════════════════════════════════════
				    // 4. TRANSFORMATION EN TABLE
				    // ═══════════════════════════════════════════════════════════════════
				    CombinedList = List.Combine(AllPages),
				    Tabled = Table.FromList(CombinedList, Splitter.SplitByNothing(), null, null, ExtraValues.Error),
				    Expanded = Table.ExpandRecordColumn(
				        Tabled, 
				        "Column1", 
				        {"id", "displayName", "userPrincipalName", "department", "country", "usageLocation", "userType", "accountEnabled", "createdDateTime", "signInActivity", "assignedLicenses"},
				        {"UserID", "DisplayName", "UserPrincipalName", "Department", "CountryOrRegion", "UsageLocation", "UserType", "AccountEnabled", "WhenCreated", "signInActivity", "Licences_Brutes"}
				    ),
				
				    // ═══════════════════════════════════════════════════════════════════
				    // 5. CALCUL DE LA DERNIÈRE ACTIVITÉ
				    // ═══════════════════════════════════════════════════════════════════
				    #"LastSignIn Ajouté" = Table.AddColumn(
				        Expanded, 
				        "LastSignIn", 
				        each 
				            if [signInActivity] <> null then 
				                let
				                    Interactive = try Record.Field([signInActivity], "lastSignInDateTime") otherwise null,
				                    NonInteractive = try Record.Field([signInActivity], "lastNonInteractiveSignInDateTime") otherwise null,
				                    DateList = List.RemoveNulls({Interactive, NonInteractive}),
				                    MaxDate = if List.IsEmpty(DateList) then null else List.Max(DateList)
				                in 
				                    MaxDate
				            else 
				                null
				    ),
				
				    #"Colonnes supprimées" = Table.RemoveColumns(#"LastSignIn Ajouté", {"signInActivity"}),
				
				    // ═══════════════════════════════════════════════════════════════════
				    // 6. TYPAGE INITIAL
				    // ═══════════════════════════════════════════════════════════════════
				    #"Type modifié" = Table.TransformColumnTypes(
				        #"Colonnes supprimées",
				        {
				            {"UsageLocation", type text},
				            {"UserType", type text},
				            {"WhenCreated", type datetime}, 
				            {"LastSignIn", type datetime}, 
				            {"AccountEnabled", type logical}
				        }
				    ),
				
				    // ═══════════════════════════════════════════════════════════════════
				    // 7. CORRECTIONS GÉOGRAPHIQUES
				    // ═══════════════════════════════════════════════════════════════════
				    #"Valeur remplacée" = Table.ReplaceValue(#"Type modifié", "Senegal", "Sénégal", Replacer.ReplaceText, {"CountryOrRegion"}),
				    #"Valeur remplacée1" = Table.ReplaceValue(#"Valeur remplacée", "Benin", "Bénin", Replacer.ReplaceText, {"CountryOrRegion"}),
				    #"Valeur remplacée2" = Table.ReplaceValue(#"Valeur remplacée1", "Mauritania", "Mauritanie", Replacer.ReplaceText, {"CountryOrRegion"}),
				    #"Valeur remplacée3" = Table.ReplaceValue(#"Valeur remplacée2", "Burkina-Faso", "Burkina Faso", Replacer.ReplaceText, {"CountryOrRegion"}),
				    #"Valeur remplacée4" = Table.ReplaceValue(#"Valeur remplacée3", "Guinea", "Guinée", Replacer.ReplaceText, {"CountryOrRegion"}),
				    #"Valeur remplacée5" = Table.ReplaceValue(#"Valeur remplacée4", "FR", "France", Replacer.ReplaceText, {"CountryOrRegion"}),
				    #"Valeur remplacée6" = Table.ReplaceValue(#"Valeur remplacée5", "Mauritius", "Maurice", Replacer.ReplaceText, {"CountryOrRegion"}),
				    #"Valeur remplacée7" = Table.ReplaceValue(#"Valeur remplacée6", "Côte d'Ivoire", "Côte d'Ivoire", Replacer.ReplaceText, {"CountryOrRegion"}),
				    #"Valeur remplacée8" = Table.ReplaceValue(#"Valeur remplacée7", "Côte***********", "Côte d'Ivoire", Replacer.ReplaceText, {"CountryOrRegion"}),
				    #"Valeur remplacée9" = Table.ReplaceValue(#"Valeur remplacée8", "Côte'Ivoire", "Côte d'Ivoire", Replacer.ReplaceText, {"CountryOrRegion"}),
				
				    // ═══════════════════════════════════════════════════════════════════
				    // 8. NOUVELLES COLONNES CALCULÉES (Phase 3)
				    // ═══════════════════════════════════════════════════════════════════
				    
				    // Extraction du domaine email
				    #"Domaine Ajouté" = Table.AddColumn(
				        #"Valeur remplacée9", 
				        "Domaine", 
				        each 
				            let 
				                email = [UserPrincipalName],
				                parts = Text.Split(email, "@")
				            in 
				                if List.Count(parts) > 1 then parts{1} else null,
				        type text
				    ),
				
				    // Calcul du nombre de jours depuis la dernière connexion
				    #"Jours Ajouté" = Table.AddColumn(
				        #"Domaine Ajouté", 
				        "JoursDepuisConnexion", 
				        each 
				            if [LastSignIn] = null then null
				            else Duration.Days(DateTime.LocalNow() - [LastSignIn]),
				        Int64.Type
				    ),
				
				    // ═══════════════════════════════════════════════════════════════════
				    // 9. RÉORGANISATION DES COLONNES
				    // ═══════════════════════════════════════════════════════════════════
				    #"Colonnes réorganisées" = Table.ReorderColumns(
				        #"Jours Ajouté", 
				        {
				            "UserID", 
				            "DisplayName", 
				            "UserPrincipalName", 
				            "Domaine",
				            "Department", 
				            "CountryOrRegion", 
				            "AccountEnabled", 
				            "WhenCreated", 
				            "LastSignIn", 
				            "JoursDepuisConnexion",
				            "Licences_Brutes"
				        }
				    )
				
				in
				    #"Colonnes réorganisées"
				```

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Exception

