	column IsCible =
			
			// Colonne calculée : identifie les comptes cibles pour le nettoyage
			// Cible = Humain actif AD mais dormant (>90j ou jamais connecté) OU tout compte désactivé AD
			(
			    T_Utilisateurs_Dim[TypeCompte] = "Utilisateur" &&
			    T_Utilisateurs_Dim[Statut AD] = "Activé" &&
			    T_Utilisateurs_Dim[CodeEtatActivite] IN {"INACTIF", "JAMAIS_CONNECTE"}
			)
			||
			T_Utilisateurs_Dim[Statut AD] = "Désactivé"
		lineageTag: iscible-calc-col-0001-neemba
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column DisplayNameAffiche =
			
			VAR _nom = TRIM(COALESCE('T_Utilisateurs_Dim'[DisplayName], ""))
			VAR _upn = TRIM(COALESCE('T_Utilisateurs_Dim'[UserPrincipalName], ""))
			RETURN
			    IF(
			        _nom <> "",
			        _nom,
			        IF(_upn <> "", _upn, "(Sans nom)")
			    )
